---
import { siteName, headerTabs } from "@shared/constants";

interface Props {
  // docs 레이아웃에서는 모바일 사이드바 토글을 노출한다.
  withSidebarToggle?: boolean;
}

const { withSidebarToggle = false } = Astro.props;

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname === href || pathname.startsWith(href + "/");
---

<header
  class="sticky top-0 z-30 h-16 border-b border-hairline bg-canvas/90 backdrop-blur-sm"
>
  <div class="flex h-16 items-center gap-4 px-4 sm:px-6">
    <!-- Left: optional sidebar toggle (docs only) + wordmark -->
    {
      withSidebarToggle && (
        <button
          id="sidebar-toggle"
          type="button"
          aria-label="목차 열기"
          aria-expanded="false"
          aria-controls="docs-sidebar"
          class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong lg:hidden"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
          </svg>
        </button>
      )
    }
    <a href="/" class="flex items-center" aria-label={`${siteName} 홈`}>
      <span class="text-[1.25rem] font-medium tracking-tight text-primary-text">{siteName}</span>
    </a>

    <!-- Center: primary tabs (desktop) -->
    <nav class="ml-4 hidden items-center gap-1 md:flex">
      {
        headerTabs.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "nav-link-type rounded-md px-3 py-2 transition-colors hover:bg-surface-strong",
              isActive(item.href) ? "text-ink" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Right: actions -->
    <div class="ml-auto flex items-center gap-1">
      <button
        type="button"
        data-search-open
        aria-label="검색 (⌘K)"
        class="hidden h-9 w-56 items-center gap-2 rounded-md border border-hairline bg-canvas-soft pr-2 pl-3 text-muted transition-colors hover:border-hairline-strong sm:inline-flex"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
        <span class="caption flex-1 text-left">문서 검색</span>
        <kbd
          class="code-type rounded border border-hairline-strong bg-surface-card px-1.5 py-0.5 text-[0.6875rem] text-muted"
          >⌘K</kbd
        >
      </button>
      <button
        type="button"
        data-search-open
        aria-label="검색"
        class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong sm:hidden"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
        </svg>
      </button>

      <!-- Theme toggle (vanilla). Icon swap is pure CSS off html[data-theme]. -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="테마 전환"
        class="grid h-9 w-9 place-items-center rounded-md text-ink transition-colors hover:bg-surface-strong"
      >
        <svg class="theme-icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        <svg class="theme-icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"></circle>
          <path
            d="M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72 1.42 1.42M2 12h2m16 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // Delegated handlers bound once on document; survive ClientRouter swaps.
  function toggleTheme() {
    const current = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
    const next = current === "dark" ? "light" : "dark";
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem("danbook-theme", next);
    } catch {
      /* storage unavailable — fine */
    }
  }

  document.addEventListener("click", (e) => {
    const target = e.target as Element | null;
    if (target?.closest("#theme-toggle")) toggleTheme();
  });
</script>
