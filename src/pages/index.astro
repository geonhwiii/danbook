---
import Layout from "../layouts/Layout.astro";
import DocsHeader from "../components/DocsHeader.astro";
import Footer from "../components/Footer.astro";
import ProgressDashboard from "../components/react/ProgressDashboard.tsx";
import { siteTagline, courses } from "@shared/constants";
import { getCourseLessons } from "@lib/docs";

// 강의 + 레슨(평탄 정렬) 메타를 클라이언트 진행률 대시보드로 넘긴다.
const courseData = await Promise.all(
  courses.map(async (course) => {
    const lessons = await getCourseLessons(course.slug);
    return {
      slug: course.slug,
      title: course.title,
      subtitle: course.subtitle,
      lessons: lessons.map((l) => ({ id: l.id, title: l.data.title })),
    };
  }),
);

const firstCourse = courses[0];
const firstLessonId = courseData[0]?.lessons[0]?.id;
---

<Layout>
  <DocsHeader />

  <div class="hero-dots relative">
    <!-- ───────────────────────── Hero ───────────────────────── -->
    <section class="container-page pt-section pb-16 text-center md:pb-20">
      <h1 class="display-hero mx-auto mt-8 max-w-4xl text-balance">
        공부한 것을<br class="hidden sm:block" /> 차곡차곡 쌓는 곳
      </h1>
      <p class="body-md mx-auto mt-6 max-w-xl text-balance text-body">
        {siteTagline}. 한 줄 명령에서 인터넷 전체까지, 직접 따라가며 익히는 학습 문서입니다.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a
          href={firstCourse ? `/docs/${firstCourse.slug}` : "/docs"}
          class="inline-flex h-13 items-center gap-2 rounded-full bg-ink px-8 text-[0.9375rem] font-medium text-canvas transition-opacity hover:opacity-90"
        >
          학습 시작하기 →
        </a>
        <button
          type="button"
          data-search-open
          aria-label="검색 (⌘K)"
          class="inline-flex h-13 items-center gap-3 rounded-full border border-hairline-strong bg-surface-card px-5 text-muted transition-colors hover:border-ink"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.6"></circle>
            <path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
          </svg>
          <span class="body-sm">문서 검색</span>
          <kbd class="code-type rounded border border-hairline px-1.5 py-1 text-[0.6875rem] text-muted-soft">⌘K</kbd>
        </button>
      </div>
    </section>
  </div>

  <!-- ───────────── 진행률 대시보드 (React island) ───────────── -->
  <section class="container-page pb-section">
    <ProgressDashboard client:load courses={courseData} />
  </section>

  <Footer />

  <style>
    .hero-dots::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      color: var(--color-ink);
      background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0);
      background-size: 15px 15px;
      background-position: 7.5px 7.5px;
      opacity: 0.08;
      -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
      mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    }

    .skill-line {
      display: block;
      font-size: clamp(2.25rem, 8vw + 1rem, 5.5rem);
      line-height: 1.04;
      letter-spacing: -0.04em;
    }
  </style>
</Layout>
